# Optional absolute backend URL for browser requests.
# Leave empty to use same-origin "/api/v1" through Next.js rewrites.
NEXT_PUBLIC_API_URL=

# Backend target for the Next.js API proxy rewrite.
# In local development this defaults to http://localhost:4000 when unset.
API_PROXY_TARGET=https://kachraalertserver.onrender.com

# Optional Socket.IO endpoint. Set when realtime should connect directly
# to a backend host instead of the API URL value.
NEXT_PUBLIC_SOCKET_URL=https://kachraalertserver.onrender.com

# Realtime alert socket toggle.
NEXT_PUBLIC_ENABLE_SOCKET=true
